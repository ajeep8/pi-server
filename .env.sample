# Required: path to your pi-coding-agent based CLI entry point
PI_AGENT_BINARY=/path/to/your/cli.ts

# Working directory for the agent process
PI_AGENT_CWD=/path/to/your/project

# Extra args passed to the agent (space-separated)
# PI_AGENT_ARGS=

# Server port
PORT=10000

# Bearer token for API authentication (disabled if unset)
# AUTH_TOKEN=

# Model name returned by /v1/models
PI_MODEL_NAME=pi-agent

# Session idle timeout in ms (default: 30 min)
SESSION_TTL_MS=1800000

# Max concurrent agent processes
MAX_SESSIONS=100

# How often to evict expired sessions (ms)
CLEANUP_INTERVAL_MS=60000
